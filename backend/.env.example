# Copy this file to .env and fill in the values. .env is gitignored.

# OAuth client ID from Google Cloud Console (Identity Services).
GOOGLE_CLIENT_ID=

# Secret used to sign session JWTs. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Comma-separated emails that get board access on sign-in.
# BOARD_EMAILS=

# Database defaults to a local H2 file; uncomment to point elsewhere (e.g. Postgres).
# DATABASE_URL=jdbc:h2:file:./data/socialcoding;MODE=PostgreSQL
# DATABASE_DRIVER=org.h2.Driver
# DATABASE_USER=sa
# DATABASE_PASSWORD=
